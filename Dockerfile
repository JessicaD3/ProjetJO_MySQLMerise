FROM node:20-alpine

WORKDIR /app

ARG DB_HOST
ARG DB_PORT
ARG DB_USER
ARG DB_PASSWORD
ARG DB_NAME
ARG DB_DW_NAME
ARG JWT_SECRET
ARG APP_URL

ENV DB_HOST=$DB_HOST
ENV DB_PORT=$DB_PORT
ENV DB_USER=$DB_USER
ENV DB_PASSWORD=$DB_PASSWORD
ENV DB_NAME=$DB_NAME
ENV DB_DW_NAME=$DB_DW_NAME
ENV JWT_SECRET=$JWT_SECRET
ENV APP_URL=$APP_URL

COPY package*.json ./
RUN npm install

COPY . .

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]